# Copie para .env (NUNCA commite o .env com senhas reais).
# Formato: VAR=valor (sem espaços ao redor do =)

NODE_ENV=production
HOST=0.0.0.0
PORT=3015

# Conexão com o banco MySQL compartilhado (mesmo banco do portal administrativo).
# Se o MySQL estiver no MESMO VPS, prefira DB_HOST=127.0.0.1
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Opcional: DB_SSL=true se o MySQL exigir SSL
# DB_SSL=true

# Opcional: limite de conexões do pool (padrão 5)
# DB_POOL_LIMIT=5

# Consulta de CNPJ: usamos a API pública gratuita OpenCNPJ (https://opencnpj.org).
# Não requer token nem configuração. Limite de 100 requisições por minuto.

# E-mail (API externa send.cadbr.com.br) — enviado ao concluir o cadastro.
EMAIL_API_URL=https://send.cadbr.com.br/sendCron
# Destino da notificação interna à equipe (opcional). Sem isso, só o cliente recebe.
EMAIL_NOTIFICATION_EMAIL=
# Opcional: sobrescrever com template do banco (templates_email). Sem isso, usa o layout institucional embutido.
# EMAIL_TEMPLATE_INICIO_ID=1
# Link do Portal do Fornecedor exibido nos e-mails.
PORTAL_URL=https://fornecedor.cadbrasil.com.br
